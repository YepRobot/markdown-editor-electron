{
  "name": "markdown-editor-electron",
  "version": "1.0.0",
  "main": "main.js",
  "scripts": {
    "test": "echo \"Error: no test specified\" && exit 1",
    "start": "electron .",
    "package": "electron-builder"
  },
  "build": {
    "appId": "com.yanpl-company.yanpl-app",
    "productName": "Markdown Editor",
    "win": {
      "target": [
        "nsis"
      ],
      "sign": false,
      "icon": "favicon.ico" 
    },
    "nsis": {
      "oneClick": false,
      "allowToChangeInstallationDirectory": true,
      "installerIcon": "favicon-sys.ico",  
      "uninstallerIcon": "favicon-run.ico",  
      "installerHeaderIcon": "favicon-install.ico"  
    }
  },
  "keywords": [],
  "author": "",
  "license": "ISC",
  "description": "",
  "dependencies": {
    "@electron/remote": "^2.1.2",
    "highlight.js": "^11.11.1",
    "markdown-it": "^14.1.0"
  },
  "devDependencies": {
    "electron": "^33.3.1",
    "electron-builder": "^25.1.8"
  }
}
